{
  "name": "node-backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "types": "index.d.ts",
  "scripts": {
    "clean": "rm -rf node_modules",
    "dev": "node --import tsx --watch --env-file-if-exists=.env src/initServer.ts",
    "dev:no-watch": "node --import tsx --env-file-if-exists=.env src/initServer.ts",
    "dev:auth": "node --import tsx --watch --env-file=.env.micro-services src/initAsMicroServices/authentication/authentication.init-server.ts",
    "dev:backend": "node --import tsx --watch --env-file=.env.micro-services src/initAsMicroServices/backend/backend.init-server.ts",
    "dev:books": "node --import tsx --watch --env-file=.env.micro-services src/initAsMicroServices/books/books.init-server.ts",
    "dev:books-grpc": "node --import tsx --watch --env-file=.env.micro-services src/initAsMicroServices/books/grpc/books-grpc.init-server.ts",
    "dev:dragons": "node --import tsx --watch --env-file=.env.micro-services src/initAsMicroServices/dragons/dragons.init-server.ts",
    "dev:file-upload": "node --import tsx --watch --env-file=.env.micro-services src/initAsMicroServices/file-upload/file-upload.init-server.ts",
    "dev:users": "node --import tsx --watch --env-file=.env.micro-services src/initAsMicroServices/users/users.init-server.ts",
    "dev:all": "./toolbox/init-micro-services.sh",
    "build": "node build.config.mjs",
    "start": "node --env-file=.env dist/index.js",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier . --check --config .prettierrc.mjs --ignore-path .prettierignore",
    "format:biome": "biome format ./src",
    "format:biome:fix": "biome format --verbose ./src --write",
    "test": "jest",
    "check": "npm run lint && npm run format:biome && npm run test",
    "benchmark": "node --env-file=.env --import tsx benchmark/benchmark.ts",
    "benchmark:quick": "concurrently -k -s first \"node --env-file=.env --import tsx src/initServer.ts\" \"npx autocannon -c 100 -d 5 -p 10 http://localhost:8000/api/health-check\"",
    "k6:smoke": "k6 run toolbox/benchmark/k6/smoke-test.js",
    "k6:load": "k6 run toolbox/benchmark/k6/load-test.js",
    "k6:stress": "k6 run toolbox/benchmark/k6/stress-test.js",
    "k6:health": "k6 run toolbox/benchmark/k6/health-check.js",
    "proto:lint": "cd src/modules/backend/proto && buf lint",
    "proto:gen": "cd src/modules/backend/proto && buf generate",
    "proto:break": "cd src/modules/backend/proto && buf breaking"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@faker-js/faker": "^10.4.0",
    "@grpc/grpc-js": "^1.14.3",
    "@socket.io/admin-ui": "^0.5.1",
    "@socket.io/redis-adapter": "^8.3.0",
    "@talkohavy/lodash": "^1.4.1",
    "api-opener": "^2.0.1",
    "color-my-json": "^0.0.9",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csv-parse": "^6.2.1",
    "helmet": "^8.1.0",
    "joi": "^18.1.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.4.1",
    "pg": "^8.20.0",
    "redis": "^5.11.0",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@eslint/js": "^10.0.1",
    "@types/autocannon": "^7.12.7",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/k6": "^1.7.0",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/ws": "^8.18.1",
    "autocannon": "^8.0.0",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-perfectionist": "^5.8.0",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "express": "^5.2.1",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "jsonc-parser": "^3.3.1",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  },
  "packageManager": "pnpm@10.33.0"
}
